{
  "title": "RecSys Service",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate",
      "targets": [
        {
          "expr": "sum(rate(recsys_recommendation_requests_total[5m])) by (endpoint, outcome)",
          "legendFormat": "{{endpoint}} {{outcome}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(recsys_recommendation_latency_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "Empty Recommendation Rate",
      "targets": [
        {
          "expr": "sum(rate(recsys_recommendation_requests_total{outcome=\"success\",empty=\"true\"}[10m])) / clamp_min(sum(rate(recsys_recommendation_requests_total{outcome=\"success\"}[10m])), 1)",
          "legendFormat": "empty"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Artifact Manifest Age",
      "targets": [
        {
          "expr": "recsys_artifact_manifest_age_seconds",
          "legendFormat": "manifest age seconds"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "Artifact Load Failures",
      "targets": [
        {
          "expr": "sum(rate(recsys_artifact_load_failures_total[5m])) by (kind)",
          "legendFormat": "{{kind}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
    },
    {
      "type": "timeseries",
      "title": "Warning Count",
      "targets": [
        {
          "expr": "sum(rate(recsys_recommendation_warnings_sum[5m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
    }
  ]
}
