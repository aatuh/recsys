---
import BaseLayout from "../../components/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { pricingPlans, localized } from "../../lib/content";

const locale = "fi";
const page = localized[locale].pages.contact;
---

<BaseLayout locale={locale} pageKey="contact" title={page.title} description={page.description}>
  <PageHero eyebrow={page.eyebrow} heading={page.heading} intro={page.intro} />
  <section class="section">
    <div class="grid cards">
      <article class="card">
        <strong>Luottamuksellinen kaupallinen yhteydenotto</strong>
        <p>Käytä LinkedIniä kaupalliseen arviointiin, lisensointiin, hankintaan ja Enterprise-laajuuden keskusteluun.</p>
        <p><a class="button secondary" href="https://www.linkedin.com/in/aatu-harju/">Lähetä viesti LinkedInissä</a></p>
      </article>
      <article class="card">
        <strong>Julkinen lisensointikysymys</strong>
        <p>Avaa julkinen GitHub issue otsikolla <code>Licensing question</code>. Älä lisää salaisuuksia, asiakasdataa tai haavoittuvuustietoja.</p>
        <p><a class="button secondary" href="https://github.com/aatuh/recsys/issues">Avaa GitHub issues</a></p>
      </article>
      <article class="card">
        <strong>Tietoturvaraportti</strong>
        <p>Käytä GitHubin yksityistä haavoittuvuusraportointia, kun se on saatavilla. Muussa tapauksessa pyydä julkisesti yksityistä kanavaa ilman arkaluonteisia tietoja.</p>
        <p><a class="button secondary" href="/fi/tietoturva/">Lue tietoturvaohje</a></p>
      </article>
    </div>
  </section>
  <section class="section">
    <p class="eyebrow">Suunnitelman konteksti</p>
    <h2>Mainitse todennäköinen suunnitelma yhteydenotossa.</h2>
    <div class="grid cards">
      {pricingPlans[locale].map((plan) => <article class="card"><strong>{plan.name}</strong><p>{plan.price} {plan.cadence}. {plan.scope}</p></article>)}
    </div>
  </section>
</BaseLayout>
