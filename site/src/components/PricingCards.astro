---
import { pricingPlans } from "../lib/content";
import { type Locale } from "../lib/routes";

const { locale } = Astro.props as { locale: Locale };
---

<div class="price-grid">
  {
    pricingPlans[locale].map((plan, index) => (
      <article class="card price-card">
        <div>
          <strong>{plan.name}</strong>
          <div class="price">
            {plan.price}
            <small>{plan.cadence}</small>
          </div>
        </div>
        <p>{plan.scope}</p>
        <a
          class="button secondary"
          href={plan.contactPath}
          data-analytics-event="cta_click"
          data-analytics-cta-id={`pricing_plan_${index + 1}`}
          data-analytics-cta-location="pricing_card"
          data-analytics-target-path={plan.contactPath}
        >
          {plan.enterprise
            ? locale === "fi"
              ? "Keskustele laajuudesta"
              : "Discuss scope"
            : locale === "fi"
              ? "Kysy suunnitelmasta"
              : "Ask about this plan"}
        </a>
      </article>
    ))
  }
</div>
