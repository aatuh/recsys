---
import "../styles/global.css";
import {
  absolutePath,
  alternatesForPage,
  languagePath,
  navLabels,
  navOrder,
  pageRoutes,
  siteName,
  siteUrl,
  type Locale,
  type PageKey,
} from "../lib/routes";

interface Props {
  locale: Locale;
  pageKey: PageKey;
  title: string;
  description: string;
  canonicalPath?: string;
  alternates?: Record<string, string>;
  languageSwitchPath?: string;
  ogType?: "website" | "article";
  jsonLd?: unknown[];
  breadcrumbTitle?: string;
}

const {
  locale,
  pageKey,
  title,
  description,
  canonicalPath = pageRoutes[pageKey][locale],
  alternates = alternatesForPage(pageKey),
  languageSwitchPath = pageRoutes[pageKey][locale === "en" ? "fi" : "en"],
  ogType = "website",
  jsonLd = [],
  breadcrumbTitle = navLabels[locale][pageKey],
} = Astro.props;

const canonicalUrl = absolutePath(canonicalPath);
const oppositeLocale: Locale = locale === "en" ? "fi" : "en";
const ogLocale = locale === "fi" ? "fi_FI" : "en_US";
const alternateOgLocale = locale === "fi" ? "en_US" : "fi_FI";
const ogImageUrl = absolutePath("/og/recsys-card.png");
const ogImageAlt =
  locale === "fi"
    ? "RecSysin arviointi-, manifesti- ja palautusnäkymä"
    : "RecSys evaluation, manifest, and rollback dashboard";

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteName,
  url: siteUrl,
  sameAs: ["https://github.com/aatuh/recsys", "https://www.linkedin.com/in/aatu-harju/"],
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
  inLanguage: ["en", "fi"],
};

const breadcrumb =
  pageKey === "home"
    ? undefined
    : {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: navLabels[locale].home,
            item: absolutePath(pageRoutes.home[locale]),
          },
          {
            "@type": "ListItem",
            position: 2,
            name: breadcrumbTitle,
            item: canonicalUrl,
          },
        ],
      };

function safeJsonLd(value: unknown): string {
  return JSON.stringify(value).replace(/</g, "\\u003c");
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {Object.entries(alternates).map(([lang, href]) => <link rel="alternate" hreflang={lang} href={href} />)}
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="theme-color" content="#f7f4ed" />
    <script is:inline type="application/ld+json" set:html={safeJsonLd(organization)} />
    <script is:inline type="application/ld+json" set:html={safeJsonLd(website)} />
    {breadcrumb && <script is:inline type="application/ld+json" set:html={safeJsonLd(breadcrumb)} />}
    {jsonLd.map((entry) => <script is:inline type="application/ld+json" set:html={safeJsonLd(entry)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main">{locale === "fi" ? "Siirry sisältöön" : "Skip to content"}</a>
    <header class="site-header">
      <div class="nav-shell">
        <a class="brand" href={languagePath("home", locale)} aria-label="RecSys">
          <span class="brand-mark" aria-hidden="true">R</span>
          <span>RecSys</span>
        </a>
        <nav class="primary-nav" aria-label={locale === "fi" ? "Päänavigaatio" : "Primary navigation"}>
          {
            navOrder.map((key) => (
              <a href={pageRoutes[key][locale]} aria-current={key === pageKey ? "page" : undefined}>
                {navLabels[locale][key]}
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <div class="language-switch" aria-label={locale === "fi" ? "Kieli" : "Language"}>
            <a href={locale === "en" ? canonicalPath : languageSwitchPath} aria-current={locale === "en" ? "true" : undefined}>
              EN
            </a>
            <a href={locale === "fi" ? canonicalPath : languageSwitchPath} aria-current={locale === "fi" ? "true" : undefined}>
              FI
            </a>
          </div>
          <a class="button primary" href={pageRoutes.contact[locale]}>{navLabels[locale].contact}</a>
        </div>
      </div>
    </header>
    <main id="main" class="page">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand" href={languagePath("home", locale)}>
            <span class="brand-mark" aria-hidden="true">R</span>
            <span>RecSys</span>
          </a>
          <p class="muted">
            {
              locale === "fi"
                ? "Itse ylläpidettävä suosittelujärjestelmä arvioitaviin julkaisuihin."
                : "Self-hosted recommendation infrastructure for evaluated rollouts."
            }
          </p>
        </div>
        <nav class="footer-links" aria-label={locale === "fi" ? "Alatunniste" : "Footer"}>
          <a href={pageRoutes.documentation[locale]}>{navLabels[locale].documentation}</a>
          <a href={pageRoutes.pricing[locale]}>{navLabels[locale].pricing}</a>
          <a href={pageRoutes.security[locale]}>{navLabels[locale].security}</a>
          <a href={pageRoutes.blog[locale]}>{navLabels[locale].blog}</a>
          <a href={pageRoutes.contact[locale]}>{navLabels[locale].contact}</a>
          <a href={oppositeLocale === "fi" ? "/fi/" : "/"}>{oppositeLocale.toUpperCase()}</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
